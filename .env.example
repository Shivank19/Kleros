# Frontend config
# Leave empty on Vercel so the frontend calls same-origin /api routes.
# Use http://localhost:3001 for local Express development.
VITE_API_BASE_URL=
VITE_USE_MOCK_AUDIT=false

# Backend LLM config
BRAIN_API_KEY=your_groq_api_key_here
BRAIN_MODEL=llama-3.3-70b-versatile
BRAIN_BASE_URL=https://api.groq.com/openai/v1
